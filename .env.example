# BioLinkMS Backend Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# Database Configuration
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://username:password@localhost:5432/biolinkms
# SQLite (for development only):
DATABASE_URL=sqlite:///./biolink.db

# JWT Security Configuration
# Generate a secure SECRET_KEY using: python -c "import secrets; print(secrets.token_urlsafe(64))"
# IMPORTANT: Change this in production! Use a different key for each environment.
SECRET_KEY=your-super-secret-key-here-min-64-chars-long-change-in-production

# JWT Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Cache (optional, for production)
# REDIS_URL=redis://localhost:6379/0

# CORS Settings (comma-separated origins)
# CORS_ORIGINS=https://biolinkms.com,https://app.biolinkms.com

# Application Settings
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# External API Keys (if needed)
# GOOGLE_MAPS_API_KEY=your-key-here
# GELOCATION_API_URL=https://api.example.com